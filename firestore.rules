rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Konsolidiertes SSOT-Ruleset für das Firebase-Projekt fitness-aos.
// Deployed NUR aus ~/vitalos (firebase deploy --only firestore:rules).
// fitness-dev und fuel-dev deployen KEINE eigenen Rules mehr — ihre
// firebase.json haben keinen firestore-Block. Vorher: fitness-dev hatte
// `allow read, write: if true` und überschrieb fuels uid-scoped Rules.
//
// Coach-Rolle: Firestore-Doc roles/{uid} mit { role: "coach" } anlegen
// (einmalig via Firebase Console oder Admin SDK). Coach darf Klienten-Daten
// lesen/schreiben (Inbox-Review, Plan-Zuweisung). Server-Sync-Prozesse
// (firestore-mirror.mjs, sync_gateway) laufen mit Admin SDK und sind von
// Rules nicht betroffen.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }
    function owner(uid) {
      return authed() && request.auth.uid == uid;
    }
    // Coach = Custom Claim (set_admin.py, bestehende Konvention) ODER roles-Doc
    function isCoach() {
      return authed() && (
        request.auth.token.coach == true
        || (exists(/databases/$(database)/documents/roles/$(request.auth.uid))
            && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'coach')
      );
    }

    // Rollen: eigene Rolle lesbar, Schreiben nur via Console/Admin SDK
    match /roles/{uid} {
      allow read: if owner(uid);
      allow write: if false;
    }

    // ── Fitness (inkl. Journal/Habits/Learn der vitalos-Shell) ──────────────
    // Userdaten: /fitness/{uid}/sessions|plan|journal|habits|habitRecords|
    //            habitJournals|inbox|profile|…
    match /fitness/{uid}/{document=**} {
      allow read, write: if owner(uid) || isCoach();
    }

    // Geteilte Exercise-KB (pseudo-uid "kb"): alle lesen, nur Coach schreibt
    // (approveInbox promoted Inbox-Einträge nach fitness/kb/exercises)
    match /fitness/kb/{document=**} {
      allow read: if authed();
      allow write: if isCoach();
    }

    // Coach-Review über alle Klienten-Inboxen (collectionGroup "inbox")
    match /{path=**}/inbox/{id} {
      allow read: if isCoach();
    }

    // ── Fuel (Nutrition & Supplements) ───────────────────────────────────────
    // /nutrition/{uid}/logs|journal|meta/… und /supplements/{uid}/logs|meta/…
    match /nutrition/{uid}/{document=**} {
      allow read, write: if owner(uid) || isCoach();
    }
    match /supplements/{uid}/{document=**} {
      allow read, write: if owner(uid) || isCoach();
    }

    // User-Settings (fuel cloud: users/{uid}/meta/settings)
    match /users/{uid}/{document=**} {
      allow read, write: if owner(uid) || isCoach();
    }

    // Geteilter Mikronährstoff-Katalog (pseudo-uid "public", read-only,
    // Pflege via Admin SDK/CLI)
    match /nutrition/public/{document=**} {
      allow read: if authed();
      allow write: if false;
    }

    // ── Relax (dritter Tempel, gleiche Struktur) ─────────────────────────────
    match /relax/{uid}/{document=**} {
      allow read, write: if owner(uid) || isCoach();
    }

    // ── Global Knowledge (KB-Sync via Admin SDK/CLI) ─────────────────────────
    match /knowledge/{document=**} {
      allow read: if authed();
      allow write: if false;
    }
    match /knowledge_tasks/{taskId} {
      allow read: if authed();
      allow create: if authed();
      allow update: if false;
    }
  }
}
