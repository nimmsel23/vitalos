{
  "name": "fitness-vos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/db.js",
    "./views/Habits": "./src/views/Habits/index.jsx",
    "./lib/db": "./src/lib/db/habits.js",
    "./lib/core": "./src/lib/db/core.js"
  },
  "scripts": {
    "dev": "vite --config vite.config.cjs",
    "build": "vite build --config vite.config.cjs",
    "build:firebase": "VITE_APP_MODE=client vite build --config vite.config.cjs",
    "build:cloud": "VITE_APP_MODE=client vite build --config vite.config.cjs",
    "firebase": "npm run build:cloud && firebase deploy --only hosting --project fitness-aos",
    "deploy": "npm run build:cloud && firebase deploy --only hosting --project fitness-aos",
    "deploy:cloud": "npm run build:cloud && firebase deploy --only hosting --project fitness-aos",
    "preview": "vite preview --config vite.config.cjs",
    "deploy:preview": "npm run build:cloud && node scripts/deploy-preview.mjs",
    "deploy:prev": "npm run deploy:preview",
    "build:preview": "npm run deploy:preview",
    "build:prev": "npm run deploy:preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "firebase": "^12.15.0",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
