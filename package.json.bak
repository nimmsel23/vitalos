{
  "name": "vitalos",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ../../server.mjs & npx vite --config vite.config.js",
    "build": "npx vite build --config vite.config.js",
    "build:firebase": "npx vite build --mode firebase --config vite.config.js && cp dist-firebase/vitalos/index.html dist-firebase/index.html && BUILD=$(date +%s) && sed -i \"s/vitalos-v[0-9]*/vitalos-$BUILD/\" dist-firebase/sw.js && sed -i \"s/\\\"version\\\": \\\"[0-9]*/\\\"version\\\": \\\"$BUILD/\" dist-firebase/manifest.json",
    "deploy:shell": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:fitness": "npx vite build --config ../federation/fitness.remote.vite.config.js && firebase deploy --only hosting --project fitness-aos --config ../fitness-dev/firebase.json",
    "deploy:fuel": "npx vite build --config ../federation/fuel.remote.vite.config.js && firebase deploy --only hosting --project fitness-aos --config /home/alpha/fuel-dev/firebase.remote.json",
    "deploy:journal": "npx vite build --config ../federation/journal.remote.vite.config.js && firebase deploy --only hosting --project fitness-aos --config ../journal-dev/firebase.remote.json",
    "deploy:learn": "npx vite build --config ../federation/learn.remote.vite.config.js && firebase deploy --only hosting --project fitness-aos --config ../learn-dev/firebase.remote.json",
    "preview": "npx vite preview --config vite.config.js"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  }
}
